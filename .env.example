# --- Server ---
FLAME_VPS_BIND_HOST=0.0.0.0
FLAME_VPS_BIND_PORT=8090

# --- Inbound RPC auth (must match FLAMEBOT_VPS_ORCH_SECRET in flame-backend) ---
FLAME_VPS_BACKEND_RPC_SECRET=change-me-shared-with-backend
FLAME_VPS_RPC_MAX_SKEW_SEC=300

# --- Outbound webhook back to backend ---
FLAME_VPS_BACKEND_WEBHOOK_URL=https://api.flamebotapp.com/vps/orchestrator/webhook
FLAME_VPS_BACKEND_WEBHOOK_SECRET=change-me-shared-with-backend
FLAME_VPS_WEBHOOK_TIMEOUT_SEC=10

# --- Persistence ---
FLAME_VPS_STATE_DB=flame_vps_state.sqlite3

# --- Provisioner roots (Windows VPS) ---
FLAME_VPS_MT_INSTALL_ROOT=C:\flame\terminals
FLAME_VPS_MT4_TEMPLATE=C:\flame\templates\mt4
FLAME_VPS_MT5_TEMPLATE=C:\flame\templates\mt5
FLAME_VPS_EA_BUNDLE_ROOT=C:\flame\ea_bundles

# --- Capacity ---
FLAME_VPS_WORKER_POOL=8
FLAME_VPS_MAX_TERMINALS_TOTAL=50

# --- Sealed-box (libsodium) private key, base64. Empty in dev. ---
FLAME_VPS_SEALEDBOX_PRIVKEY_B64=
